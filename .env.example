# ─── Application ────────────────────────────────────────────────────────────
ENV=development
APP_NAME="Solidcare V2"
APP_VERSION="2.0.0"
DEBUG=true
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://solidcare:solidcare@localhost:5432/solidcare_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────────────────────────
# Set REDIS_ENABLED=false for minimum-cost Azure demo (no Azure Cache for Redis)
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Azure Storage ───────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=solidcare-documents
AZURE_STORAGE_BLOB_URL_EXPIRY_HOURS=1

# ─── Azure Key Vault (production only) ───────────────────────────────────────
AZURE_KEY_VAULT_URL=https://solidcare-kv.vault.azure.net/
USE_KEY_VAULT=false

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGE_ME
EMAIL_FROM_ADDRESS=noreply@solidcare.health
EMAIL_FROM_NAME="Solidcare Health"

# ─── SMS (MSG91) ─────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=CHANGE_ME
MSG91_SENDER_ID=SOLID
MSG91_DLT_ENTITY_ID=CHANGE_ME
MSG91_DLT_TEMPLATE_ID_APPOINTMENT=CHANGE_ME

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ─── Application Insights ────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
